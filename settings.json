{
  "autoUpdatesChannel": "latest",
  "enabledMcpjsonServers": [
    "qmd",
    "cognitive-memory"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v qmd > /dev/null 2>&1 && qmd embed",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__cognitive-memory__*",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$HOOK_INPUT\" | jq -c '{hookSpecificOutput: {hookEventName: \"PreToolUse\", permissionDecision: \"allow\", updatedInput: .}}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/post-tool-session-note.mjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/semantic-hydration.mjs"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/break-enforcement.mjs"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/post-tool-failure.mjs"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/task-completed.mjs"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(bun *)",
      "mcp__cognitive-memory__read_entity",
      "mcp__cognitive-memory__list_entities",
      "mcp__cognitive-memory__add_session_note",
      "mcp__qmd__search",
      "mcp__qmd__vector_search",
      "mcp__qmd__deep_search",
      "mcp__qmd__get",
      "mcp__qmd__multi_get",
      "mcp__qmd__status"
    ]
  },
  "env": {
    "MCP_TOOL_TIMEOUT": "240000",
    "COGNITIVE_MEMORY_PATH": "{{MEMORY_PATH}}"
  },
  "showClearContextOnPlanAccept": true
}
