{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__cognitive-memory__*",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$HOOK_INPUT\" | jq -c '{hookSpecificOutput: {hookEventName: \"PreToolUse\", permissionDecision: \"allow\", updatedInput: .}}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/post-tool-session-note.mjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/semantic-hydration.mjs"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/break-enforcement.mjs"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/post-tool-failure.mjs"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__cognitive-memory__*",
      "mcp__qmd__*",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(bun *)"
    ]
  },
  "env": {
    "MCP_TOOL_TIMEOUT": "120000"
  }
}
